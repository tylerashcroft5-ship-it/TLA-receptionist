# ── TLA Receptionist environment ──────────────────────────────────
# Copy to `.env` and fill in. Never commit `.env`.

# Vapi (telephony + turn-taking orchestration)
# Get from https://dashboard.vapi.ai  →  free trial credit, no card to start
VAPI_API_KEY=

# Shared secret you invent — Vapi sends it back on every webhook so we can
# verify the request really came from Vapi. Put the same value in the
# assistant's server.secret when provisioning.
VAPI_WEBHOOK_SECRET=change-me-to-a-long-random-string

# ElevenLabs (the British human voice — the make-or-break)
# https://elevenlabs.io  →  free tier for testing
ELEVENLABS_API_KEY=
# Voice id of the chosen British voice (see README → picking the voice)
ELEVENLABS_VOICE_ID=

# Deepgram (speech-to-text) — https://deepgram.com  →  free credit
DEEPGRAM_API_KEY=

# Anthropic (the brain). Vapi calls Claude directly using this key.
# SEPARATE from your Claude Code plan — this is api.anthropic.com billing.
ANTHROPIC_API_KEY=

# Where this webhook server is reachable by Vapi (public URL).
# In dev use an ngrok/cloudflared tunnel; in prod your deployed URL.
PUBLIC_BASE_URL=https://your-tunnel-or-deploy-url

# ── Per-client business details (the receptionist's "knowledge") ───
# For a real multi-client setup these move to a DB keyed by phone number.
# For the first build we keep one client inline.
CLIENT_BUSINESS_NAME=Example Plumbing Ltd
CLIENT_BUSINESS_HOURS=Mon-Fri 8am-6pm, Sat 9am-1pm
CLIENT_TRANSFER_NUMBER=+44...
CLIENT_BOOKING_URL=https://cal.com/...
CLIENT_OWNER_EMAIL=owner@example.co.uk

PORT=3100
